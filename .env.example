# ============================================================
#  LocallyAI — environment configuration template
#  Copy this file to .env and fill in every required value.
#  Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
#  REQUIRED — server will refuse to start without these
# ------------------------------------------------------------

# Long random secret used to authenticate all admin API calls.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LOCALLYAI_ADMIN_KEY=

# Secret salt for pseudonymising usernames in audit.log (GDPR Article 25).
# Without this, user hashes are reversible by anyone with a staff list.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LOCALLYAI_AUDIT_SALT=

# Secret key for the HMAC chain that makes audit.log tamper-evident (ISO 27001 A.12.4).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LOCALLYAI_AUDIT_HMAC_KEY=


# ------------------------------------------------------------
#  SERVER
# ------------------------------------------------------------

# Port the API listens on.
PORT=8000

# Inference backend: "ollama" (default) or "mlx" (Apple Silicon only).
LOCALLYAI_BACKEND=ollama

# Comma-separated list of allowed CORS origins.
# Restrict to the specific IP/hostname of your client machines in production.
LOCALLYAI_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Set to 1 ONLY on an isolated LAN with no TLS certificates.
# Leave unset (or blank) in all other environments.
# LOCALLYAI_ALLOW_HTTP=1

# Internal base URL used by the heartbeat and resurrector to probe the API.
LOCALLYAI_API_BASE=http://localhost:8000

# Set to 1 to disable vector search and run in basic LLM-only mode.
# SAFE_MODE=1


# ------------------------------------------------------------
#  MODEL
# ------------------------------------------------------------

# Ollama model used for inference.
OLLAMA_MODEL=qwen2.5-coder:7b

# Ollama model used for document embeddings.
EMBED_MODEL=nomic-embed-text:latest

# Base URL for the local Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434

# MLX model path — only required when LOCALLYAI_BACKEND=mlx.
# MLX_MODEL=mlx-community/Mistral-7B-Instruct-v0.3-4bit


# ------------------------------------------------------------
#  STORAGE & LOGGING
# ------------------------------------------------------------

# Directory where Qdrant vector DB and BM25 index are stored.
# Defaults to production/storage if unset.
# LOCALLYAI_STORAGE_DIR=/path/to/storage

# Directory where all log files are written.
# Defaults to production/logs if unset.
# LOCALLYAI_LOG_DIR=/path/to/logs

# Disk path monitored for free-space alerts.
# Defaults to C:\ on Windows, / on Linux/Mac.
# LOCALLYAI_DISK_CHECK_PATH=C:\


# ------------------------------------------------------------
#  SECURITY — failed login lockout (ISO 27001 A.9)
# ------------------------------------------------------------

# Number of failed attempts before an IP is locked out.
LOCALLYAI_LOCKOUT_MAX=10

# Rolling window (seconds) in which failures are counted.
LOCALLYAI_LOCKOUT_WINDOW=300

# How long (seconds) a locked IP stays locked.
LOCALLYAI_LOCKOUT_DURATION=900


# ------------------------------------------------------------
#  ALERTING — at least one channel recommended in production
# ------------------------------------------------------------

# HTTP POST webhook for alerts (Slack, Teams, PagerDuty, etc.).
# LOCALLYAI_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# SMTP email alerting (warning and critical levels only).
# LOCALLYAI_SMTP_HOST=smtp.example.com
# LOCALLYAI_SMTP_PORT=587
# LOCALLYAI_SMTP_USER=alerts@example.com
# LOCALLYAI_SMTP_PASS=
# LOCALLYAI_ALERT_EMAIL=ops@example.com

# Human-readable label for this deployment — appears in all alert messages.
LOCALLYAI_DEPLOYMENT_ID=locallyai-prod


# ------------------------------------------------------------
#  HEARTBEAT — watchdog probe settings
# ------------------------------------------------------------

# How often (seconds) the heartbeat probes the API.
HB_INTERVAL=30

# Consecutive failures before the resurrector is triggered.
HB_MAX_FAILURES=3

# Per-probe HTTP timeout (seconds).
HB_TIMEOUT=10

# Cooldown (seconds) before the resurrector can be triggered again.
# Prevents double-triggering during a slow recovery.
HB_RECOVERY_COOLDOWN=120


# ------------------------------------------------------------
#  FIRM IDENTITY + REGION (read by the bootstrap script)
# ------------------------------------------------------------

# Display name for the deploying firm. Used to compute firm_id
# (SHA-256("locallyai-firm:<name>")[:16]) for telemetry attribution.
LOCALLYAI_FIRM_NAME=Example LLP

# UK | KSA — selects regional defaults (DPA template, Arabic UI strings,
# Hijri date formatting, regulator references).
LOCALLYAI_DATA_REGION=UK

# Channel for auto-updates: stable | edge.
LOCALLYAI_UPDATE_CHANNEL=stable

# Hostname staff laptops use to reach the office Mac (mDNS).
LOCALLYAI_OFFICE_HOST=office-mac.local

# 127.0.0.1 for single-Mac deployments; 0.0.0.0 for fleet deployments
# where staff laptops on the LAN must reach the API.
LOCALLYAI_BIND=127.0.0.1


# ------------------------------------------------------------
#  EMBEDDING BACKEND
# ------------------------------------------------------------

# http (default — OpenAI-compatible HTTP server, e.g. Ollama or LM Studio)
# or local (in-process sentence-transformers; required for offline /
# air-gapped Mac deployments). Mixing backends in the same Qdrant
# collection silently breaks retrieval, so this is asserted strictly.
EMBED_BACKEND=http

# When EMBED_BACKEND=local on Apple Silicon, this is the
# sentence-transformers model used. Multilingual e5-base is the
# default for UK + KSA bilingual deployments.
# EMBED_MODEL=intfloat/multilingual-e5-base


# ------------------------------------------------------------
#  TELEMETRY (vendor health dashboard)
# ------------------------------------------------------------

# off (default) | on. The firm chooses; default off.
LOCALLYAI_TELEMETRY=off

# URL of the vendor monitor Worker.
# LOCALLYAI_TELEMETRY_URL=https://locallyai-monitor.your-cf-account.workers.dev

# Per-firm telemetry token (auto-issued at form-submit time by the
# vendor monitor's /onboarding/mint-token endpoint). Bootstrap fills
# this in automatically; you should not need to set it by hand.
# LOCALLYAI_TELEMETRY_TOKEN=


# ------------------------------------------------------------
#  KILL SWITCH (vendor-side emergency disable)
# ------------------------------------------------------------

# URL of the vendor kill-switch Worker. The firm's deployment polls
# this; a tripped switch refuses to start.
# LOCALLYAI_KILL_SWITCH_URL=https://locallyai-killswitch.your-cf-account.workers.dev/status.json

# 1 = refuse to start if the kill-switch URL is unreachable; 0 = best-effort.
LOCALLYAI_KILL_SWITCH_REQUIRED=1

# 1 = require Ed25519 signature on the kill-switch payload;
# 0 = relaxed (development / demo only — never in production).
LOCALLYAI_KILL_SWITCH_SIG_REQUIRED=1


# ------------------------------------------------------------
#  AUTO-UPDATE
# ------------------------------------------------------------

# on | off — whether to apply vendor releases automatically.
LOCALLYAI_AUTO_UPDATE=on

# Comma-separated update tiers to auto-apply: A (security patches),
# B (minor features), C (major upgrades). Higher tiers require manual ack.
LOCALLYAI_AUTO_UPDATE_TIERS=A


# ------------------------------------------------------------
#  AUDIT SALT ROTATION (filled in by scripts/rotate_audit_salt.sh)
# ------------------------------------------------------------

# When the active LOCALLYAI_AUDIT_SALT is rotated, the previous salt
# is preserved as LOCALLYAI_AUDIT_SALT_ERA_<N> so old pseudonyms can
# still be re-identified for GDPR erasure / subject access.
# Add more eras (ERA_2, ERA_3, ...) as rotations happen.
# LOCALLYAI_AUDIT_SALT_ERA_1=


# ------------------------------------------------------------
#  EXTERNAL QDRANT (optional — for fleet HA)
# ------------------------------------------------------------

# Leave blank to use the embedded Qdrant (single-process).
# Set to http://qdrant-host:6333 (or docker-compose service name)
# for a shared Qdrant accessed by both HA peers.
QDRANT_URL=
