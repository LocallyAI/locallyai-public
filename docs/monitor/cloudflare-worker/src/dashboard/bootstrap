#!/usr/bin/env bash
# LocallyAI install bootstrap.
#
# This script is served from the monitor Worker as a static asset.
# It is GPG-signed; the detached signature is at the same URL with
# `.sig` appended. The vendor's release-signing public key is at:
#   https://raw.githubusercontent.com/LocallyAI/locallyai/main/docs/release-signing-key.gpg
#
# To verify before running (recommended for production firms):
#   curl -fsSL https://locallyai-monitor.<vendor-cf>.workers.dev/bootstrap     > /tmp/locallyai-bootstrap
#   curl -fsSL https://locallyai-monitor.<vendor-cf>.workers.dev/bootstrap.sig > /tmp/locallyai-bootstrap.sig
#   gpg --verify /tmp/locallyai-bootstrap.sig /tmp/locallyai-bootstrap
#   # "Good signature" → safe to run:
#   LOCALLYAI_INTAKE='...' bash /tmp/locallyai-bootstrap
#
# The form's "Generate install command" button assembles the one-liner.

set -euo pipefail

BOOTSTRAP_VERSION="1.0.0"
INSTALL_DIR="${LOCALLYAI_INSTALL_DIR:-$HOME/locallyai}"
REPO_URL="${LOCALLYAI_REPO_URL:-git@github.com:LocallyAI/locallyai.git}"
REPO_BRANCH="${LOCALLYAI_REPO_BRANCH:-main}"

die()  { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; exit 1; }
info() { printf '  %s\n' "$*"; }
step() { printf '\n\033[1;34m▸\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m  ✓\033[0m %s\n' "$*"; }

# ── /dev/tty handle ─────────────────────────────────────────────────────
# When this script is invoked via `curl ... | bash`, stdin is the curl
# pipe — already at EOF by the time we want to prompt. All interactive
# reads go through /dev/tty instead so they reach the user's terminal
# regardless of how the script was launched.
[ -r /dev/tty ] && [ -w /dev/tty ] \
  || die "this script needs an interactive terminal but /dev/tty is unavailable. Re-run from an interactive shell session."

# ── Pre-flight ──────────────────────────────────────────────────────────

[ "${BASH_VERSINFO:-0}" -ge 3 ] || die "bash 3.2+ required"
command -v git        >/dev/null || die "git not found — install from https://git-scm.com/"
command -v curl       >/dev/null || die "curl not found"
command -v ssh-agent  >/dev/null || die "ssh-agent not found"
command -v ssh-add    >/dev/null || die "ssh-add not found"
command -v base64     >/dev/null || die "base64 not found"

# macOS base64 doesn't support -d on older versions; check both flags.
if echo "dGVzdAo=" | base64 -d >/dev/null 2>&1; then B64D="base64 -d"
elif echo "dGVzdAo=" | base64 -D >/dev/null 2>&1; then B64D="base64 -D"
else die "base64 doesn't support -d or -D"
fi

# Two ways to provide the intake (form picks one):
#   - LOCALLYAI_INTAKE_URL: bootstrap fetches the blob itself (cleaner
#     one-liner; matches the PowerShell bootstrap). Single-use — fetch
#     consumes the token server-side.
#   - LOCALLYAI_INTAKE: legacy inline base64 blob.
INTAKE="${LOCALLYAI_INTAKE:-}"
if [ -z "$INTAKE" ] && [ -n "${LOCALLYAI_INTAKE_URL:-}" ]; then
  INTAKE="$(curl -fsSL "$LOCALLYAI_INTAKE_URL" 2>/dev/null || true)"
  if [ -z "$INTAKE" ]; then
    die "Could not fetch intake from \$LOCALLYAI_INTAKE_URL. The link may have already been used (single-use) — regenerate from the form."
  fi
fi
if [ -z "$INTAKE" ]; then
  die "Neither LOCALLYAI_INTAKE_URL nor LOCALLYAI_INTAKE set. Get the install command from the intake form at the onboarding URL your vendor sent."
fi

# Decode + sanity-check the blob now, before any side effects.
INTAKE_DECODED="$(printf '%s' "$INTAKE" | $B64D 2>/dev/null || true)"
echo "$INTAKE_DECODED" | grep -q "^LOCALLYAI_FIRM_NAME=" \
  || die "intake blob is malformed — re-copy the install command from the form"
FIRM_NAME="$(echo "$INTAKE_DECODED" | awk -F= '/^LOCALLYAI_FIRM_NAME=/{sub(/^LOCALLYAI_FIRM_NAME=/, ""); gsub(/"/, ""); print; exit}')"
REGION="$(echo "$INTAKE_DECODED" | awk -F= '/^LOCALLYAI_DATA_REGION=/{sub(/^LOCALLYAI_DATA_REGION=/, ""); print; exit}')"

# ── Show what we're about to do ─────────────────────────────────────────

cat <<EOF

  ════════════════════════════════════════════════════════════════════
   LocallyAI install bootstrap v$BOOTSTRAP_VERSION

   Firm:        $FIRM_NAME
   Region:      ${REGION:-(unset)}
   Install at:  $INSTALL_DIR
   From:        $REPO_URL ($REPO_BRANCH)

   This script will:
     1. Prompt for your LocallyAI deploy key + telemetry token
        (paste from 1Password — values are never echoed or saved)
     2. Set up a temporary ssh-agent with the deploy key
     3. Clone the LocallyAI repo to the install dir
     4. Write .env from the intake values + your telemetry token
     5. Run install.sh

   Ctrl-C now to abort. Press Enter to continue.
  ════════════════════════════════════════════════════════════════════
EOF
read -r _ < /dev/tty

# ── Collect secrets (interactive, never via env) ────────────────────────

step "Deploy key — PRIVATE key issued by your LocallyAI vendor"

DEPLOY_KEY=""

# Preferred path: env-var with file path. Vendor places the key on the
# office Mac before running bootstrap, sets the env var in the curl
# command, and skips pasting entirely. Most reliable.
if [ -n "${LOCALLYAI_DEPLOY_KEY_FILE:-}" ]; then
  [ -f "$LOCALLYAI_DEPLOY_KEY_FILE" ] \
    || die "LOCALLYAI_DEPLOY_KEY_FILE='$LOCALLYAI_DEPLOY_KEY_FILE' is not a readable file"
  info "Reading deploy key from \$LOCALLYAI_DEPLOY_KEY_FILE"
  DEPLOY_KEY="$(cat "$LOCALLYAI_DEPLOY_KEY_FILE")"
fi

# Fallback path 1: prompt for a file path (or drag-and-drop into Terminal).
if [ -z "$DEPLOY_KEY" ]; then
  echo "  Enter the FULL PATH to the private key file."
  echo "    Example: /Users/me/.ssh/locallyai_deploy"
  echo "    (Tip: in Terminal, drag the file in and the path appears for you.)"
  echo "    Or press Enter to paste the key contents instead."
  printf "  Path: "
  IFS= read -r KEY_PATH < /dev/tty || KEY_PATH=""
  # Trim a trailing space (drag-and-drop adds one) and surrounding quotes.
  KEY_PATH="${KEY_PATH% }"
  KEY_PATH="${KEY_PATH#\"}"; KEY_PATH="${KEY_PATH%\"}"
  KEY_PATH="${KEY_PATH#\'}"; KEY_PATH="${KEY_PATH%\'}"
  # Expand a leading ~ (read doesn't do tilde expansion).
  case "$KEY_PATH" in "~"|"~/"*) KEY_PATH="${HOME}${KEY_PATH#\~}" ;; esac
  if [ -n "$KEY_PATH" ]; then
    [ -f "$KEY_PATH" ] || die "no file at: $KEY_PATH"
    DEPLOY_KEY="$(cat "$KEY_PATH")"
    ok "Loaded key from $KEY_PATH"
  fi
fi

# Fallback path 2: paste contents inline.
if [ -z "$DEPLOY_KEY" ]; then
  echo ""
  echo "  Paste the WHOLE key — the BEGIN line, all the gibberish, the END line."
  echo "  When you're done, press RETURN, then Ctrl-D on the new empty line."
  echo ""
  DEPLOY_KEY="$(cat /dev/tty)"
fi

# ── Validate ────────────────────────────────────────────────────────────
if [ -z "$DEPLOY_KEY" ]; then
  die "no key provided. Re-run and either set LOCALLYAI_DEPLOY_KEY_FILE, enter the file path at the prompt, or paste the key contents."
fi

# Common mistake: pasted the .pub file. Catch with a specific message.
if echo "$DEPLOY_KEY" | head -1 | grep -qE '^(ssh-(ed25519|rsa|dss)|ecdsa-) '; then
  die "this is the PUBLIC key (starts with 'ssh-…'). We need the matching PRIVATE key — same filename without the .pub. Vendor sent both files; pick the one without .pub."
fi

# Truly malformed paste. Print enough info that the user can self-diagnose
# without showing the secret content.
if ! echo "$DEPLOY_KEY" | grep -q -- "-----BEGIN.*PRIVATE KEY-----"; then
  LINES="$(echo "$DEPLOY_KEY" | wc -l | tr -d ' ')"
  BYTES="$(printf '%s' "$DEPLOY_KEY" | wc -c | tr -d ' ')"
  FIRST_LINE="$(echo "$DEPLOY_KEY" | head -1)"
  echo ""
  echo "  Diagnostic:"
  echo "    Lines received: $LINES"
  echo "    Bytes received: $BYTES"
  echo "    First line (truncated to 60 chars): ${FIRST_LINE:0:60}"
  echo ""
  die "no '-----BEGIN ... PRIVATE KEY-----' header found. Most common causes: (1) pasted the public key (.pub) by mistake; (2) Terminal mangled the multi-line paste (try LOCALLYAI_DEPLOY_KEY_FILE=/path/to/key instead)."
fi
if ! echo "$DEPLOY_KEY" | grep -q -- "-----END.*PRIVATE KEY-----"; then
  die "key looks truncated (BEGIN header but no END footer). Try the file-path option — paste-via-Terminal can drop content on long keys."
fi

step "Telemetry token (the 64-char hex from 1Password)"
echo "  Press Enter to skip (you can add it to .env later)."
printf "  Token: "
read -rs TELEMETRY_TOKEN < /dev/tty
echo ""
if [ -n "$TELEMETRY_TOKEN" ]; then
  echo "$TELEMETRY_TOKEN" | grep -qE "^[0-9a-fA-F]{64}$" \
    || die "telemetry token is not 64 hex characters — re-copy from 1Password"
  ok "Telemetry token captured (hidden)"
else
  info "Skipping telemetry token — will need to be added to .env manually"
fi

# ── SSH agent + known_hosts ─────────────────────────────────────────────

step "Setting up SSH for git clone"
eval "$(ssh-agent -s)" >/dev/null
trap 'ssh-agent -k >/dev/null 2>&1 || true' EXIT
echo "$DEPLOY_KEY" | ssh-add - >/dev/null 2>&1 \
  || die "ssh-add rejected the deploy key — verify the paste was complete"
ok "Deploy key loaded into temporary agent (key is never written to disk)"

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"
touch "$HOME/.ssh/known_hosts"
# Pin GitHub's published SSH host key fingerprints. The Worker also
# serves these at /github-known-hosts so we don't have to inline.
if ! grep -q "^github.com" "$HOME/.ssh/known_hosts"; then
  ssh-keyscan -t ed25519,rsa github.com 2>/dev/null >> "$HOME/.ssh/known_hosts"
  ok "github.com added to known_hosts"
fi

# ── Clone or update the repo ────────────────────────────────────────────

step "Cloning $REPO_URL → $INSTALL_DIR"
if [ -d "$INSTALL_DIR/.git" ]; then
  info "Repo already exists; fetching latest from $REPO_BRANCH"
  ( cd "$INSTALL_DIR" && git fetch origin "$REPO_BRANCH" && git checkout "$REPO_BRANCH" && git pull --ff-only origin "$REPO_BRANCH" )
else
  mkdir -p "$(dirname "$INSTALL_DIR")"
  git clone --branch "$REPO_BRANCH" "$REPO_URL" "$INSTALL_DIR"
fi
ok "Repo ready at $INSTALL_DIR"

# ── Write .env ──────────────────────────────────────────────────────────

step "Writing $INSTALL_DIR/.env"
{
  echo "# Generated by LocallyAI install bootstrap v$BOOTSTRAP_VERSION on $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# Source: intake form at https://locallyai-monitor.<vendor-cf>.workers.dev/onboarding.html"
  echo ""
  echo "$INTAKE_DECODED"
  [ -n "$TELEMETRY_TOKEN" ] && echo "LOCALLYAI_TELEMETRY_TOKEN=$TELEMETRY_TOKEN"
} > "$INSTALL_DIR/.env"
chmod 600 "$INSTALL_DIR/.env"
unset TELEMETRY_TOKEN DEPLOY_KEY
ok ".env written (mode 0600)"

# ── Run install.sh ──────────────────────────────────────────────────────

step "Running install.sh"
cd "$INSTALL_DIR"
[ -x "./install.sh" ] || chmod +x ./install.sh
# Redirect install.sh's stdin to the real terminal. Without this, when the
# bootstrap was invoked via `curl ... | bash`, install.sh inherits the dead
# curl pipe and its first `read -rp` gets immediate EOF → crash.
exec ./install.sh < /dev/tty
