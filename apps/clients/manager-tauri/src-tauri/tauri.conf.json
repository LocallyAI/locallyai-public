{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "LocallyAI Manager",
  "version": "1.0.0",
  "identifier": "app.locallyai.client.manager",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "LocallyAI Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "LocallyAI Manager — secure local AI for the firm",
    "longDescription": "Standalone client for the LocallyAI Manager UI. Connects to the firm's on-premises LocallyAI server.",
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    }
  }
}
